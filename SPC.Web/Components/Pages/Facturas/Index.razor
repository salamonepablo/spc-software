@page "/facturas"
@using SPC.Web.Services
@using SPC.Web.Services.Models
@using SPC.Web.Components.Shared
@inject IApiService Api
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Invoices - SPC</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Invoices</h3>
        <div class="text-muted">
            @if (totalInvoices > 0)
            {
                <span>@totalInvoices facturas en el sistema</span>
            }
        </div>
    </div>

    @* Resumen de facturacion *@
    @if (resumen != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h6 class="card-title opacity-75">Hoy</h6>
                        <h3 class="mb-0">@resumen.MontoHoy.ToString("C0")</h3>
                        <small>@resumen.InvoicesHoy facturas</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h6 class="card-title opacity-75">Este Mes</h6>
                        <h3 class="mb-0">@resumen.MontoMes.ToString("C0")</h3>
                        <small>@resumen.InvoicesMes facturas</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h6 class="card-title opacity-75">Este Ano</h6>
                        <h3 class="mb-0">@resumen.MontoAnio.ToString("C0")</h3>
                        <small>total acumulado</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-secondary text-white">
                    <div class="card-body">
                        <h6 class="card-title opacity-75">Total Historico</h6>
                        <h3 class="mb-0">@resumen.TotalInvoices.ToString("N0")</h3>
                        <small>facturas emitidas</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <input type="text" 
                               class="form-control" 
                               placeholder="Buscar por numero, cliente o CUIT..."
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearchKeyUp" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="Search">
                            Buscar
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text">Desde</span>
                        <input type="date" class="form-control" @bind="fechaDesde" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text">Hasta</span>
                        <input type="date" class="form-control" @bind="fechaHasta" />
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="FilterByDate">
                        Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <LoadingSpinner Message="Cargando facturas..." />
    }
    else if (facturas == null || facturas.Count == 0)
    {
        <div class="alert alert-info">
            No se encontraron facturas con los criterios seleccionados.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Numero</th>
                                <th>Fecha</th>
                                <th>Customer</th>
                                <th>CUIT</th>
                                <th class="text-end">Total</th>
                                <th>CAE</th>
                                <th>Estado</th>
                                <th style="width: 100px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var factura in facturas)
                            {
                                <tr class="@(factura.Anulada ? "table-danger text-muted" : "")">
                                    <td>
                                        <strong>@factura.NumeroCompleto</strong>
                                    </td>
                                    <td>@factura.FechaInvoice.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @factura.CustomerRazonSocial
                                    </td>
                                    <td><small>@(factura.CustomerCUIT ?? "-")</small></td>
                                    <td class="text-end">
                                        <strong>@factura.Total.ToString("C2")</strong>
                                    </td>
                                    <td>
                                        @if (factura.TieneCAE)
                                        {
                                            <span class="badge bg-success" title="@factura.CAE">AFIP</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (factura.Anulada)
                                        {
                                            <span class="badge bg-danger">Anulada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">OK</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" 
                                                @onclick="() => VerDetalle(factura.Id)"
                                                title="Ver detalle">
                                            Ver
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (facturas.Count >= pageSize)
            {
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Mostrando @facturas.Count facturas</span>
                        <button class="btn btn-outline-primary" @onclick="LoadMore">
                            Cargar mas...
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Modal para ver detalle *@
@if (facturaSeleccionada != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Invoice @facturaSeleccionada.NumeroCompleto</h5>
                    <button type="button" class="btn-close" @onclick="CerrarDetalle"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Customer:</strong> @facturaSeleccionada.CustomerRazonSocial</p>
                            <p><strong>CUIT:</strong> @(facturaSeleccionada.CustomerCUIT ?? "-")</p>
                        </div>
                        <div class="col-md-6 text-end">
                            <p><strong>Fecha:</strong> @facturaSeleccionada.FechaInvoice.ToString("dd/MM/yyyy")</p>
                            @if (facturaSeleccionada.TieneCAE)
                            {
                                <p><strong>CAE:</strong> @facturaSeleccionada.CAE</p>
                            }
                        </div>
                    </div>
                    
                    <table class="table table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Codigo</th>
                                <th>Descripcion</th>
                                <th class="text-end">Cant.</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var det in facturaSeleccionada.Detalles)
                            {
                                <tr>
                                    <td><code>@det.ProductCodigo</code></td>
                                    <td>@det.ProductDescripcion</td>
                                    <td class="text-end">@det.Cantidad.ToString("N0")</td>
                                    <td class="text-end">@det.PrecioUnitario.ToString("C2")</td>
                                    <td class="text-end">@det.Subtotal.ToString("C2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end">@facturaSeleccionada.Subtotal.ToString("C2")</td>
                            </tr>
                            @if (facturaSeleccionada.ImporteIVA > 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-end">IVA:</td>
                                    <td class="text-end">@facturaSeleccionada.ImporteIVA.ToString("C2")</td>
                                </tr>
                            }
                            @if (facturaSeleccionada.ImporteDescuento > 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-end">Descuento:</td>
                                    <td class="text-end text-danger">-@facturaSeleccionada.ImporteDescuento.ToString("C2")</td>
                                </tr>
                            }
                            <tr class="table-primary">
                                <td colspan="4" class="text-end"><strong>TOTAL:</strong></td>
                                <td class="text-end"><strong>@facturaSeleccionada.Total.ToString("C2")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarDetalle">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<InvoiceDto>? facturas;
    private InvoicecionResumenDto? resumen;
    private InvoiceCompletaDto? facturaSeleccionada;
    private bool loading = true;
    private string searchTerm = "";
    private DateTime fechaDesde = DateTime.Today.AddMonths(-1);
    private DateTime fechaHasta = DateTime.Today;
    private int totalInvoices = 0;
    private int pageSize = 50;
    private int currentPage = 0;

    protected override async Task OnInitializedAsync()
    {
        var resumenTask = Api.GetInvoicecionResumenAsync();
        var facturasTask = Api.GetInvoicesAsync(0, pageSize);
        var countTask = Api.GetInvoicesCountAsync();

        await Task.WhenAll(resumenTask, facturasTask, countTask);

        resumen = await resumenTask;
        facturas = await facturasTask;
        totalInvoices = await countTask;
        loading = false;
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadInvoices();
            return;
        }

        loading = true;
        try
        {
            facturas = await Api.BuscarInvoicesAsync(searchTerm);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task FilterByDate()
    {
        loading = true;
        try
        {
            facturas = await Api.GetInvoicesByFechaAsync(fechaDesde, fechaHasta);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadInvoices()
    {
        currentPage = 0;
        loading = true;
        try
        {
            facturas = await Api.GetInvoicesAsync(0, pageSize);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadMore()
    {
        currentPage++;
        var more = await Api.GetInvoicesAsync(currentPage * pageSize, pageSize);
        if (more.Any())
        {
            facturas?.AddRange(more);
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private async Task VerDetalle(int id)
    {
        facturaSeleccionada = await Api.GetInvoiceAsync(id);
    }

    private void CerrarDetalle()
    {
        facturaSeleccionada = null;
    }
}
