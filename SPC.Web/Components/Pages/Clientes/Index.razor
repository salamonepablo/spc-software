@page "/clientes"
@using SPC.Web.Services
@using SPC.Web.Services.Models
@using SPC.Web.Components.Shared
@inject IApiService Api
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Customers - SPC</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Customers</h3>
        <a href="/clientes/nuevo" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nuevo Customer
        </a>
    </div>

    @if (alertMessage != null)
    {
        <AlertMessage Message="@alertMessage" 
                      Type="@alertType" 
                      OnDismiss="() => alertMessage = null" />
    }

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" 
                               class="form-control" 
                               placeholder="Buscar por nombre o razón social..."
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearchKeyUp" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="Search">
                            Buscar
                        </button>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                                Limpiar
                            </button>
                        }
                    </div>
                </div>
                <div class="col-md-6 text-end text-muted">
                    @if (clientes != null)
                    {
                        <span>@clientes.Count cliente(s) encontrado(s)</span>
                    }
                </div>
            </div>

            @if (loading)
            {
                <LoadingSpinner Message="Cargando clientes..." />
            }
            else if (clientes == null || clientes.Count == 0)
            {
                <div class="alert alert-info">
                    @if (string.IsNullOrEmpty(searchTerm))
                    {
                        <span>No hay clientes registrados. <a href="/clientes/nuevo">Crear el primero</a></span>
                    }
                    else
                    {
                        <span>No se encontraron clientes con el término "@searchTerm"</span>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Codigo</th>
                                <th>Razon Social</th>
                                <th>CUIT</th>
                                <th>Localidad</th>
                                <th>Telefono</th>
                                <th>Cond. IVA</th>
                                <th style="width: 150px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in clientes)
                            {
                                <tr>
                                    <td><code>@cliente.Id</code></td>
                                    <td>
                                        <strong>@cliente.RazonSocial</strong>
                                        @if (!string.IsNullOrEmpty(cliente.NombreFantasia))
                                        {
                                            <br /><small class="text-muted">@cliente.NombreFantasia</small>
                                        }
                                    </td>
                                    <td>@(cliente.CUIT ?? "-")</td>
                                    <td>@(cliente.Localidad ?? "-")</td>
                                    <td>@(cliente.Telefono ?? cliente.Celular ?? "-")</td>
                                    <td>@(cliente.TaxConditionDescripcion ?? "-")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/clientes/editar/@cliente.Id" 
                                               class="btn btn-outline-primary" 
                                               title="Editar">
                                                Editar
                                            </a>
                                            <button class="btn btn-outline-danger" 
                                                    title="Eliminar"
                                                    @onclick="() => ShowDeleteConfirm(cliente)">
                                                Eliminar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<ConfirmDialog Title="Eliminar Customer"
               Message="@deleteConfirmMessage"
               ConfirmText="Eliminar"
               IsVisible="showDeleteConfirm"
               OnClose="HandleDeleteConfirm" />

@code {
    private List<CustomerDto>? clientes;
    private bool loading = true;
    private string searchTerm = "";
    
    // Alert state
    private string? alertMessage;
    private AlertMessage.AlertType alertType;
    
    // Delete confirmation state
    private bool showDeleteConfirm;
    private CustomerDto? clienteToDelete;
    private string deleteConfirmMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        loading = true;
        try
        {
            clientes = await Api.GetCustomersAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadCustomers();
            return;
        }

        loading = true;
        try
        {
            clientes = await Api.BuscarCustomersAsync(searchTerm);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ClearSearch()
    {
        searchTerm = "";
        await LoadCustomers();
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private void ShowDeleteConfirm(CustomerDto cliente)
    {
        clienteToDelete = cliente;
        deleteConfirmMessage = $"¿Está seguro que desea eliminar al cliente \"{cliente.RazonSocial}\"? Esta acción no se puede deshacer.";
        showDeleteConfirm = true;
    }

    private async Task HandleDeleteConfirm(bool confirmed)
    {
        showDeleteConfirm = false;

        if (confirmed && clienteToDelete != null)
        {
            var success = await Api.DeleteCustomerAsync(clienteToDelete.Id);
            
            if (success)
            {
                alertMessage = $"Customer \"{clienteToDelete.RazonSocial}\" eliminado correctamente.";
                alertType = AlertMessage.AlertType.Success;
                await LoadCustomers();
            }
            else
            {
                alertMessage = "Error al eliminar el cliente. Intente nuevamente.";
                alertType = AlertMessage.AlertType.Error;
            }
        }

        clienteToDelete = null;
    }
}
