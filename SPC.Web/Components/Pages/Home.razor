@page "/"
@using SPC.Web.Services.Models
@inject IApiService Api
@rendermode InteractiveServer

<PageTitle>SPC - Sistema de Gestion</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h4 class="fw-bold">Bienvenido a SPC - Software</h4>
            <p class="text-muted">Sistema de Gestion Integral - ERP</p>
        </div>
    </div>

    @* Primera fila: Customers, Products, Stock *@
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title fw-bold fs-5">Customers</h5>
                    <p class="card-text">Gestion de clientes, condiciones comerciales y datos de contacto.</p>
                    @if (clientesCount.HasValue)
                    {
                        <p class="h3 text-primary">@clientesCount.Value.ToString("N0")</p>
                        <small class="text-muted">clientes activos</small>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/clientes" class="btn btn-primary">Ir a Customers</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title fw-bold fs-5">Products</h5>
                    <p class="card-text">Catalogo de productos, precios y categorias.</p>
                    @if (productosCount.HasValue)
                    {
                        <p class="h3 text-primary">@productosCount.Value.ToString("N0")</p>
                        <small class="text-muted">productos activos</small>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/productos" class="btn btn-primary">Ir a Products</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-success">
                <div class="card-body">
                    <h5 class="card-title fw-bold fs-5">Stock</h5>
                    <p class="card-text">Control de inventario por deposito y alertas de stock minimo.</p>
                    @if (stockValor.HasValue)
                    {
                        <p class="h3 text-success">@stockValor.Value.ToString("C0")</p>
                        <small class="text-muted">valor total en stock</small>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/stock" class="btn btn-success">Ir a Stock</a>
                </div>
            </div>
        </div>
    </div>

    @* Segunda fila: Invoicecion *@
    <div class="row g-4 mt-2">
        <div class="col-md-8">
            <div class="card h-100 border-warning">
                <div class="card-body">
                    <h5 class="card-title fw-bold fs-5">Invoicecion</h5>
                    <p class="card-text">Consulta de facturas emitidas con integracion AFIP.</p>
                    @if (facturacionResumen != null)
                    {
                        <div class="row">
                            <div class="col-4">
                                <p class="h4 text-warning mb-0">@facturacionResumen.TotalInvoices.ToString("N0")</p>
                                <small class="text-muted">facturas totales</small>
                            </div>
                            <div class="col-4">
                                <p class="h4 text-success mb-0">@facturacionResumen.MontoMes.ToString("C0")</p>
                                <small class="text-muted">este mes</small>
                            </div>
                            <div class="col-4">
                                <p class="h4 text-info mb-0">@facturacionResumen.MontoAnio.ToString("C0")</p>
                                <small class="text-muted">este ano</small>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/facturas" class="btn btn-warning">Ver Invoices</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-secondary">
                <div class="card-body">
                    <h5 class="card-title fw-bold fs-5">Cuentas Corrientes</h5>
                    <p class="card-text">Saldos de clientes y movimientos de cuenta.</p>
                    <p class="h4 text-secondary">Proximamente</p>
                    <small class="text-muted">en desarrollo</small>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-secondary" disabled>Proximamente</button>
                </div>
            </div>
        </div>
    </div>

    @* Estado del sistema *@
    <div class="row mt-5">
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title">Estado del Sistema</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <strong>API:</strong>
                            @if (apiStatus == true)
                            {
                                <span class="badge bg-success ms-2">Conectado</span>
                            }
                            else if (apiStatus == false)
                            {
                                <span class="badge bg-danger ms-2">Desconectado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-2">Verificando...</span>
                            }
                        </div>
                        <div class="col-md-3">
                            <strong>Base de Datos:</strong>
                            <span class="badge bg-info ms-2">SQL Server</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Version:</strong> <span class="text-muted">1.0.0-dev</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Fecha:</strong> <span class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int? clientesCount;
    private int? productosCount;
    private decimal? stockValor;
    private InvoicecionResumenDto? facturacionResumen;
    private bool? apiStatus;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var clientesTask = Api.GetCustomersAsync();
            var productosTask = Api.GetProductsAsync();
            var stockTask = Api.GetStockResumenAsync();
            var facturacionTask = Api.GetInvoicecionResumenAsync();
            
            await Task.WhenAll(clientesTask, productosTask, stockTask, facturacionTask);
            
            clientesCount = (await clientesTask).Count;
            productosCount = (await productosTask).Count;
            
            var stockList = await stockTask;
            stockValor = stockList.Sum(s => s.ValorStock);
            
            facturacionResumen = await facturacionTask;
            
            apiStatus = true;
        }
        catch
        {
            apiStatus = false;
        }
    }
}
