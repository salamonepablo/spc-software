@page "/productos/nuevo"
@using SPC.Web.Services
@using SPC.Web.Services.Models
@using SPC.Web.Components.Shared
@inject IApiService Api
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Nuevo Product - SPC</PageTitle>

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/productos">Products</a></li>
            <li class="breadcrumb-item active">Nuevo</li>
        </ol>
    </nav>

    <h4 class="fw-bold mb-4">Nuevo Product</h4>

    @if (errorMessage != null)
    {
        <AlertMessage Message="@errorMessage" 
                      Type="AlertMessage.AlertType.Error" 
                      OnDismiss="() => errorMessage = null" />
    }

    <div class="card">
        <div class="card-body">
            <EditForm Model="producto" OnValidSubmit="HandleSubmit" FormName="CreateProduct">
                <DataAnnotationsValidator />
                
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3">Datos del Product</h5>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label for="codigo" class="form-label">Código *</label>
                                <InputText id="codigo" class="form-control" @bind-Value="producto.Codigo" />
                                <ValidationMessage For="() => producto.Codigo" class="text-danger" />
                            </div>
                            <div class="col-md-8 mb-3">
                                <label for="codigoProveedor" class="form-label">Código Proveedor</label>
                                <InputText id="codigoProveedor" class="form-control" @bind-Value="producto.CodigoProveedor" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="descripcion" class="form-label">Descripción *</label>
                            <InputText id="descripcion" class="form-control" @bind-Value="producto.Descripcion" />
                            <ValidationMessage For="() => producto.Descripcion" class="text-danger" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="rubro" class="form-label">Category</label>
                                <InputSelect id="rubro" class="form-select" @bind-Value="producto.CategoryId">
                                    <option value="">-- Seleccionar --</option>
                                    @foreach (var rubro in rubros)
                                    {
                                        <option value="@rubro.Id">@rubro.Nombre</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="unidadMedida" class="form-label">Unidad de Medida</label>
                                <InputSelect id="unidadMedida" class="form-select" @bind-Value="producto.UnitOfMeasureId">
                                    <option value="">-- Seleccionar --</option>
                                    @foreach (var um in unidadesMedida)
                                    {
                                        <option value="@um.Id">@um.Nombre (@um.Codigo)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="mb-3">Precios y Stock</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="precioCosto" class="form-label">Precio Costo</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber id="precioCosto" class="form-control" @bind-Value="producto.PrecioCosto" />
                                </div>
                                <ValidationMessage For="() => producto.PrecioCosto" class="text-danger" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="precioVenta" class="form-label">Precio Venta</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber id="precioVenta" class="form-control" @bind-Value="producto.PrecioVenta" />
                                </div>
                                <ValidationMessage For="() => producto.PrecioVenta" class="text-danger" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="porcentajeIva" class="form-label">% IVA</label>
                                <div class="input-group">
                                    <InputNumber id="porcentajeIva" class="form-control" @bind-Value="producto.PorcentajeIVA" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <ValidationMessage For="() => producto.PorcentajeIVA" class="text-danger" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="stockMinimo" class="form-label">Stock Mínimo</label>
                                <InputNumber id="stockMinimo" class="form-control" @bind-Value="producto.StockMinimo" />
                                <ValidationMessage For="() => producto.StockMinimo" class="text-danger" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="observaciones" class="form-label">Observaciones</label>
                            <InputTextArea id="observaciones" class="form-control" rows="3" @bind-Value="producto.Observaciones" />
                            <ValidationMessage For="() => producto.Observaciones" class="text-danger" />
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">
                    <a href="/productos" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Guardar
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private CreateProductDto producto = new();
    private List<CategoryDto> rubros = new();
    private List<UnitOfMeasureDto> unidadesMedida = new();
    
    private bool saving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Load dropdown data in parallel
        var rubrosTask = Api.GetCategorysAsync();
        var unidadesTask = Api.GetUnidadesMedidaAsync();

        await Task.WhenAll(rubrosTask, unidadesTask);

        rubros = await rubrosTask;
        unidadesMedida = await unidadesTask;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        try
        {
            var result = await Api.CreateProductAsync(producto);

            if (result != null)
            {
                Navigation.NavigateTo("/productos?created=true");
            }
            else
            {
                errorMessage = "Error al crear el producto. Verifique los datos e intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}
